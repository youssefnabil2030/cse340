<link rel="stylesheet" href="/css/style.css" />

<main class="content-block">
  <h1>Service Categories</h1>
  <p class="subtitle">Filter community outreach initiatives by primary service domain.</p>

  <% if (categories && categories.length > 0) { %>
    <ul class="categories-list">
      <% categories.forEach(function(category) { %>
        <li class="category-item">
          <div class="category-image-wrapper">
            <img 
              src="<%= category.image_url || 'https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=500&auto=format&fit=crop&q=80' %>" 
              alt="<%= category.name %> Image" 
              class="category-card-img"
              loading="lazy"
              onerror="this.src='https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=500&auto=format&fit=crop&q=80';"
            />
          </div>
          <div class="category-info">
            <span class="category-title"><%= category.name %></span>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p class="subtitle">No service categories listed in the database system.</p>
  <% } %>
</main>
