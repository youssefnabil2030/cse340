<!-- Inside views/categories.ejs categories.forEach loop -->
<li class="category-item" data-id="<%= category.id %>">
    <!-- Card Image Header (Circular now) -->
    <div class="category-image-wrapper">
        <img src="<%= imageUrl %>" alt="<%= category.name %>" class="category-card-img" loading="lazy">
    </div>
    
    <!-- Card Body Details -->
    <div class="category-info">
        <!-- Changed to use the new CSS class for icon -->
        <span class="material-symbols-rounded category-icon">folder_open</span>
        <span class="category-title"><%= category.name %></span>
    </div>
</li>