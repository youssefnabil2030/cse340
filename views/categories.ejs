<%- include('partials/header') %>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet">

<section class="content-block">
    <h1><%= pageTitle %></h1>
    <p class="subtitle">Browse our service opportunities by choosing a category below:</p>

    <ul class="categories-list">
        <% 
        // Map category names to high-quality Unsplash images dynamically
        const imageMap = {
            'Environmental': 'https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?w=500&auto=format&fit=crop&q=60',
            'Educational': 'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=500&auto=format&fit=crop&q=60',
            'Community Service': 'https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=500&auto=format&fit=crop&q=60',
            'Health and Wellness': 'https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=500&auto=format&fit=crop&q=60'
        };
        
        // Fallback image in case a new category is added to the database
        const defaultImage = 'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=500&auto=format&fit=crop&q=60';
        %>

        <% categories.forEach(category => { 
            // Resolve the image URL based on the category name
            const imageUrl = imageMap[category.name] || defaultImage;
        %>
            <li class="category-item" data-id="<%= category.id %>">
                <div class="category-image-wrapper">
                    <img src="<%= imageUrl %>" alt="<%= category.name %>" class="category-card-img" loading="lazy">
                </div>
                
                <div class="category-info">
                    <span class="material-symbols-rounded" style="font-size: 28px; color: #3b82f6;">folder_open</span>
                    <span class="category-title"><%= category.name %></span>
                </div>
            </li>
        <% }) %>
    </ul>
</section>

<%- include('partials/footer') %>