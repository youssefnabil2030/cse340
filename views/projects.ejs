<%- include('partials/header') %>

<main class="content-block">
  <h1>Community Projects</h1>
  <p class="subtitle">Explore active initiatives driving community outreach and environmental protection.</p>

  <% if (projects && projects.length > 0) { %>
    <div class="card-grid">
      <% projects.forEach(function(project) { %>
        <article class="card-item">
          <!-- Project Card Image -->
          <div class="category-image-wrapper">
            <img 
              src="<%= project.image_url || 'https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=600&auto=format&fit=crop&q=80' %>" 
              alt="<%= project.name %> Image" 
              class="category-card-img"
              loading="lazy"
              onerror="this.src='https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=600&auto=format&fit=crop&q=80';"
            />
          </div>

          <div class="card-header-flex" style="justify-content: space-between; padding: 1rem 1rem 0 1rem;">
            <h2 class="card-title"><%= project.name %></h2>
            <span class="badge badge-active">Active</span>
          </div>

          <div class="card-body">
            <p class="card-description"><%= project.description %></p>
            <ul class="meta-list">
              <li><strong>Organization ID:</strong> #<%= project.organization_id %></li>
              <li><strong>Start Date:</strong> <%= new Date(project.start_date).toLocaleDateString() %></li>
            </ul>
          </div>

          <div class="card-footer" style="justify-content: space-between; align-items: center;">
            <span class="badge badge-progress">Community Initiative</span>
            <span style="font-size: 0.8rem; color: var(--text-muted);">ID: <%= project.project_id %></span>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <p class="subtitle">No active projects currently available in the database system.</p>
  <% } %>
</main>

<%- include('partials/footer') %>
