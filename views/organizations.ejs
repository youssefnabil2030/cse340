<div class="card-grid">
  <% organizations.forEach(function(org) { %>
    <div class="org-card">
      <!-- Dynamic Logo Rendering -->
      <img 
        src="/images/logos/<%= org.logo_filename %>" 
        alt="<%= org.name %> Logo" 
        class="org-logo"
        onerror="this.src='/images/logos/default-logo.png';" 
      />
      <h2><%= org.name %></h2>
      <p><%= org.description %></p>
      
      <ul class="meta-info">
        <li><strong>Location:</strong> <%= org.location %></li>
        <li><strong>Email:</strong> <a href="mailto:<%= org.contact_email %>"><%= org.contact_email %></a></li>
        <li><strong>Established:</strong> <%= new Date(org.date_created).toLocaleDateString() %></li>
      </ul>
    </div>
  <% }) %>
</div>
