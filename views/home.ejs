<%- include('partials/header') %>

<main class="content-block">
  <div class="hero-section">
    <div class="hero-text">
      <h1>Community Service Network</h1>
      <p class="subtitle">Connecting volunteers, non-profits, and active outreach projects in one platform.</p>
      <div class="hero-actions">
        <a href="/projects" class="btn-primary">Explore Projects &rarr;</a>
        <a href="/organizations" class="btn-secondary">View Organizations</a>
      </div>
    </div>
    <div class="hero-image-wrapper">
      <img 
        src="https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=800&auto=format&fit=crop&q=80" 
        alt="Community Service Hero" 
        class="hero-img"
        loading="lazy"
      />
    </div>
  </div>

  <div class="card-grid">
    <article class="card-item">
      <div class="card-body">
        <h2 class="card-title">Partner Organizations</h2>
        <p class="card-description">Discover non-profits driving local sustainability and education.</p>
      </div>
      <div class="card-footer">
        <a href="/organizations" class="btn-sm">Browse Organizations &rarr;</a>
      </div>
    </article>

    <article class="card-item">
      <div class="card-body">
        <h2 class="card-title">Active Projects</h2>
        <p class="card-description">Explore active river cleanups, food drives, and youth mentoring.</p>
      </div>
      <div class="card-footer">
        <a href="/projects" class="btn-sm">View Projects &rarr;</a>
      </div>
    </article>

    <article class="card-item">
      <div class="card-body">
        <h2 class="card-title">Service Categories</h2>
        <p class="card-description">Filter initiatives by domain — from disaster relief to environmental care.</p>
      </div>
      <div class="card-footer">
        <a href="/categories" class="btn-sm">Explore Categories &rarr;</a>
      </div>
    </article>
  </div>
</main>
