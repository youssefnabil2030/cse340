<link rel="stylesheet" href="/css/style.css" />

<main class="content-block">
  <div class="hero-section">
    <div class="hero-text">
      <h1>Empowering Local Communities</h1>
      <p class="subtitle">Connecting volunteers, non-profits, and active projects to create real-world impact.</p>
      <div class="hero-actions">
        <a href="/projects" class="btn-primary">Explore Projects</a>
        <a href="/organizations" class="btn-secondary">Partner Organizations</a>
      </div>
    </div>
    <div class="hero-image-wrapper">
      <img 
        src="https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=800&auto=format&fit=crop&q=80" 
        alt="Community Service Hero" 
        class="hero-img"
        loading="lazy"
      />
    </div>
  </div>

  <section class="stats-grid">
    <div class="stat-card">
      <h3>Active Projects</h3>
      <p class="stat-number">24+</p>
    </div>
    <div class="stat-card">
      <h3>Partner Non-Profits</h3>
      <p class="stat-number">12</p>
    </div>
    <div class="stat-card">
      <h3>Service Domains</h3>
      <p class="stat-number">6</p>
    </div>
  </section>
</main>
